# Jira MCP Server Configuration
#
# NOTE: For Cursor IDE or Claude Desktop, configure these in your MCP client
# settings instead of using this file. See README.md for details.
#
# This file is only needed for SSE transport mode (HTTP server).

# ===========================================
# Required: Jira Server Configuration
# ===========================================
JIRA_SERVER_URL=https://jira.example.com
JIRA_PERSONAL_ACCESS_TOKEN=your-personal-access-token-here

# Optional: SSL Verification (set to false for self-signed certificates)
JIRA_VERIFY_SSL=true

# ===========================================
# Database Configuration (for activity tracking & reports)
# ===========================================

# Option 1: SQLite (default - no configuration needed)
# Just set the data directory where the SQLite file will be stored
JIRA_MCP_DATA_DIR=./data

# Option 2: PostgreSQL (for production deployments)
# Uncomment and configure the DATABASE_URL to use PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/jira_mcp

# ===========================================
# PostgreSQL Settings (only if using docker-compose with postgres profile)
# ===========================================
# POSTGRES_USER=jira_mcp
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=jira_mcp
